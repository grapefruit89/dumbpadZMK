#include <physical_layouts.dtsi>

/ {
    layouts {
        compatible = "zmk,physical-layouts";
        default_layout: default_layout {
            compatible = "zmk,physical-layout";
            display-name = "Default Layout";
            transform = <&default_transform>;
            kscan = <&kscan0>;
            keys  // Koordinaten für ZMK Studio (Breite Höhe X Y Rot Spalte Zeile)
                = <&key_physical_attrs 100 100 0 0 0 0 0>
                , <&key_physical_attrs 100 100 100 0 0 1 0>
                , <&key_physical_attrs 100 100 200 0 0 2 0>
                , <&key_physical_attrs 100 100 300 0 0 3 0>
                , <&key_physical_attrs 100 100 400 0 0 4 0> // Encoder-Button RC(0,4)
                
                , <&key_physical_attrs 100 100 0 100 0 0 1>
                , <&key_physical_attrs 100 100 100 100 0 1 1>
                , <&key_physical_attrs 100 100 200 100 0 2 1>
                , <&key_physical_attrs 100 100 300 100 0 3 1>
                
                , <&key_physical_attrs 100 100 0 200 0 0 2>
                , <&key_physical_attrs 100 100 100 200 0 1 2>
                , <&key_physical_attrs 100 100 200 200 0 2 2>
                , <&key_physical_attrs 100 100 300 200 0 3 2>
                
                , <&key_physical_attrs 100 100 0 300 0 0 3>
                , <&key_physical_attrs 100 100 100 300 0 1 3>
                , <&key_physical_attrs 100 100 200 300 0 2 3>
                , <&key_physical_attrs 100 100 300 300 0 3 3>
                ;
        };
    };
};
